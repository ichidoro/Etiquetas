{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server/server.ts",
    "build": "vite build --config config/vite.config.ts && esbuild server/server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --tsconfig=config/tsconfig.json --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview --config config/vite.config.ts",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --project config/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@libsql/client": "^0.17.3",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.22.2",
    "jsbarcode": "^3.12.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "papaparse": "^5.5.3",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsbarcode": "^3.11.4",
    "@types/node": "^22.14.0",
    "@types/papaparse": "^5.5.2",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
